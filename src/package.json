{
    "private": true,
    "scripts": {
        "dev": "npm run development",
        "development": "mix",
        "watch": "mix watch",
        "watch-poll": "mix watch -- --watch-options-poll=1000",
        "hot": "mix watch --hot",
        "prod": "npm run production",
        "production": "mix --production",
        "build:css": "tailwindcss -i ./resources/css/app.css -o ./public/css/layouts.css",
        "watch:css": "tailwindcss -i ./resources/css/app.css -o ./public/css/layouts.css --watch"
    },
    "devDependencies": {
        "autoprefixer": "^10.4.27",
        "axios": "^0.21",
        "laravel-mix": "^6.0.6",
        "lodash": "^4.17.19",
        "postcss": "^8.5.8",
        "tailwindcss": "^3.4.13"
    }
}